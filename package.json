{
  "name": "anupubba",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Gamified Pali vocabulary for dharma practitioners — gradual, step-by-step, in due order",
  "license": "MIT",
  "author": "Mark Ferree",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc -b",
    "icons": "node scripts/gen-icons.mjs",
    "verify": "npm run lint && npm run test && npm run build"
  },
  "dependencies": {
    "idb": "^8.0.3",
    "preact": "^10.29.4",
    "ts-fsrs": "^5.2.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@preact/preset-vite": "^2.10.5",
    "@testing-library/preact": "^3.2.4",
    "@types/node": "^26.1.0",
    "eslint": "^10.6.0",
    "fake-indexeddb": "^6.2.5",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.3",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.10"
  }
}
