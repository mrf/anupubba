  "talk": [
    { "text": "We begin by taking refuge. The " },
    { "term": "buddha", "surface": "buddha" },
    { "text": " is not a god but a teacher — one who woke up. The " },
    { "term": "dhamma", "surface": "dhamma" },
    { "text": " he pointed to is both the teaching and the way things actually are. And the " },
    { "term": "sangha", "surface": "saṅgha" },
    { "text": " carries the practice forward, so that no one sits alone." }
