  "talk": [
    { "text": "The wheel turns fast. Out of " },
    { "term": "avijja", "surface": "avijjā" },
    { "text": " — not seeing clearly — " },
    { "term": "sankhara", "surface": "saṅkhārā" },
    { "text": " shape a world, and " },
    { "term": "vinnana", "surface": "viññāṇa" },
    { "text": " lights it up. Where sense meets object, " },
    { "term": "phassa", "surface": "phassa" },
    { "text": " sparks " },
    { "term": "vedana", "surface": "vedanā" },
    { "text": " — and if the feeling is pleasant, " },
    { "term": "tanha", "surface": "taṇhā" },
    { "text": " reaches. Craving hardens into " },
    { "term": "upadana", "surface": "upādāna" },
    { "text": ", clinging builds " },
    { "term": "bhava", "surface": "bhava" },
    { "text": ", and becoming delivers " },
    { "term": "jati", "surface": "jāti" },
    { "text": " — a self, born again into the story. But the chain has a weak link: right where " },
    { "term": "vedana", "surface": "vedanā" },
    { "text": " turns to " },
    { "term": "tanha", "surface": "taṇhā" },
    { "text": ", " },
    { "term": "sati", "surface": "sati" },
    { "text": " can hold the line." }
  ],
  "suttaRec": {
    "title": "Kaccānagotta — Right View",
    "ref": "sn12.15",
    "url": "https://suttacentral.net/sn12.15",
    "blurb": "\"By and large, this world depends on a duality — existence and non-existence.\" The short discourse on the middle way between the two.",
    "minutes": 4
  }
}
