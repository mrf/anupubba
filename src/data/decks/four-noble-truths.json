  "talk": [
    { "text": "The four truths turn on craving. " },
    { "term": "dukkha", "surface": "dukkha" },
    { "text": " has a cause: " },
    { "term": "tanha", "surface": "taṇhā" },
    { "text": ", the thirst that keeps us leaning into the next moment. Its " },
    { "term": "samudaya", "surface": "samudaya" },
    { "text": " is how suffering arises; its " },
    { "term": "nirodha", "surface": "nirodha" },
    { "text": " is suffering's ending — " },
    { "term": "nibbana", "surface": "nibbāna" },
    { "text": ", the flame blown out. The " },
    { "term": "magga", "surface": "magga" },
    { "text": " is the road between them." }
