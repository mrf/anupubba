  "name": "The Three Marks",
  "paliName": "tilakkhaṇa",
  "order": 2,
  "intro": "Three characteristics show up in every experience, when looked at closely enough.",
  "words": [
    {
      "id": "anicca",
      "pali": "anicca",
      "gloss": "impermanent; inconstant",
      "literal": "not lasting",
      "etymology": { "root": "a- + nicca (constant)", "note": "the negation of permanence — already changing as we meet it" },
