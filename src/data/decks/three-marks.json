      ],
      "pronunciation": "uh-NICH-cha"
    },
    {
      "id": "dukkha",
      "pali": "dukkha",
      "gloss": "suffering; unsatisfactoriness; stress",
      "literal": "hard to bear; the bad axle-hole",
      "etymology": { "root": "du (bad) + kha (axle-hole)", "note": "a wheel mounted off-center — life that rides rough" },
      "cluster": "three-marks",
      "confusables": [],
      "canonicalLine": {
        "pali": "sabbe saṅkhārā dukkhā",
