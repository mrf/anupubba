      "gloss": "not-self; without fixed essence",
      "literal": "not self",
      "etymology": { "root": "an- + attā (self)", "note": "nothing in experience holds still long enough to be a self" },
      "cluster": "three-marks",
      "confusables": ["anicca"],
      "canonicalLine": {
