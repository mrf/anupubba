  "talk": [
    { "text": "Look closely at any experience and three marks appear. It is " },
    { "term": "anicca", "surface": "anicca" },
    { "text": " — already changing as we meet it. Grasping at what changes brings " },
    { "term": "dukkha", "surface": "dukkha" },
    { "text": ". And nowhere in it can a fixed self be found — this is " },
    { "term": "anatta", "surface": "anattā" },
    { "text": ". The " },
    { "term": "dhamma", "surface": "dhamma" },
    { "text": " is simply this, seen clearly." }
  ],
  "suttaRec": {
    "title": "Maggavagga — The Path (Dhammapada 273–289)",
    "ref": "dhp273-289",
    "url": "https://suttacentral.net/dhp273-289",
    "blurb": "The three marks, three verses in a row — aniccā, dukkhā, anattā — each ending: seeing this, one turns away from suffering.",
    "minutes": 4
  }
