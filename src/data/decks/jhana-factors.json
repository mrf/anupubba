  "talk": [
    { "text": "The first jhāna has five factors. " },
    { "term": "vitakka", "surface": "vitakka" },
    { "text": " places the mind on the breath; " },
    { "term": "vicara", "surface": "vicāra" },
    { "text": " keeps it there, examining. From seclusion come " },
    { "term": "piti", "surface": "pīti" },
    { "text": " — rapture, the body flooded with joyful energy — and " },
    { "term": "sukha", "surface": "sukha" },
    { "text": ", a happiness quieter and steadier than pīti. " },
    { "term": "ekaggata", "surface": "ekaggatā" },
    { "text": " gathers everything into one point. This is " },
    { "term": "samadhi", "surface": "samādhi" },
    { "text": " ripening." }
