  "talk": [
    { "text": "Sit down and the hindrances arrive like weather. " },
    { "term": "kamacchanda", "surface": "kāmacchanda" },
    { "text": " reaches for something more pleasant than the breath; " },
    { "term": "byapada", "surface": "byāpāda" },
    { "text": " pushes against what is already here. " },
    { "term": "thinamiddha", "surface": "thīnamiddha" },
    { "text": " pulls the mind under, while " },
    { "term": "uddhaccakukkucca", "surface": "uddhaccakukkucca" },
    { "text": " shakes it — replaying what was said, rehearsing what is next. And " },
    { "term": "vicikiccha", "surface": "vicikicchā" },
    { "text": " whispers: is this even working? None of them are enemies. Met with " },
    { "term": "sati", "surface": "sati" },
    { "text": ", named and known, each one loosens — and the water clears toward " },
    { "term": "samadhi", "surface": "samādhi" },
    { "text": "." }
  ],
  "suttaRec": {
    "title": "Saṅgārava — The Bowl of Water",
    "ref": "sn46.55",
    "url": "https://suttacentral.net/sn46.55",
    "blurb": "Each hindrance as a bowl of water — dyed, boiling, mossy, wind-churned, muddy — and why verses won't come to mind when the water is disturbed.",
    "minutes": 8
  }
