  "talk": [
    { "text": "What we call a self, the teaching unbundles into five heaps. " },
    { "term": "rupa", "surface": "rūpa" },
    { "text": " — the body, the material. " },
    { "term": "vedana", "surface": "vedanā" },
    { "text": " — the immediate tone: pleasant, unpleasant, neither. " },
    { "term": "sanna", "surface": "saññā" },
    { "text": " — recognition, naming what appears. " },
    { "term": "sankhara", "surface": "saṅkhāra" },
    { "text": " — the constructing impulses that lean toward or away. " },
    { "term": "vinnana", "surface": "viññāṇa" },
    { "text": " — the knowing of it all. Each one is " },
    { "term": "anicca", "surface": "anicca" },
    { "text": ", and each is " },
    { "term": "anatta", "surface": "anattā" },
    { "text": " — not mine, not me." }
  ],
  "suttaRec": {
    "title": "Anattalakkhaṇa — The Not-Self Characteristic",
