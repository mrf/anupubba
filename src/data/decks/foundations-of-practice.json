  "talk": [
    { "text": "In sitting, the factors sort themselves out. " },
    { "term": "sati", "surface": "sati" },
    { "text": " remembers to be present; " },
    { "term": "sampajanna", "surface": "sampajañña" },
    { "text": " knows clearly what is happening. Settling deepens into " },
    { "term": "samatha", "surface": "samatha" },
    { "text": ", and gathering deepens into " },
    { "term": "samadhi", "surface": "samādhi" },
    { "text": ". From that stillness, " },
    { "term": "vipassana", "surface": "vipassanā" },
    { "text": " sees the three marks directly — and seeing ripens into " },
    { "term": "panna", "surface": "paññā" },
    { "text": ". When " },
    { "term": "tanha", "surface": "taṇhā" },
    { "text": " arises, " },
    { "term": "sati", "surface": "sati" },
    { "text": " simply notices." }
  ],
  "suttaRec": {
    "title": "Aggi Sutta — Fire",
    "ref": "sn46.53",
    "url": "https://suttacentral.net/sn46.53",
    "blurb": "When the mind is sluggish, which factors to stoke; when restless, which to cool. And the line you learned: mindfulness is useful everywhere.",
    "minutes": 6
  }
